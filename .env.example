# .env.example
# Copy to .env.local and fill in real values. .env.local is gitignored.
# Phase 1 only uses the first three. Other variables are placeholders documenting the full forward view.

# --- Supabase (Phase 1) ---
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...your-anon-key...
SUPABASE_SERVICE_ROLE_KEY=eyJ...your-service-role-key-SERVER-ONLY...

# --- Anthropic (Phase 2 — required) ---
ANTHROPIC_API_KEY=sk-ant-api03-REPLACE_ME

# --- Exa (Phase 3 — required) ---
EXA_API_KEY=exa_your_key_here

# --- Upstash Redis (Phase 2 — required) ---
UPSTASH_REDIS_REST_URL=https://REPLACE_ME.upstash.io
UPSTASH_REDIS_REST_TOKEN=REPLACE_ME

# --- Resend (Phase 4 — required) ---
# Get key from https://resend.com/api-keys (free tier: 3k emails/month)
RESEND_API_KEY=re_REPLACE_ME
# Verified sender; for dev use onboarding@resend.dev (no DNS setup needed)
RESEND_FROM_EMAIL=onboarding@resend.dev
# Destination for per-session + alarm emails (Joe's inbox)
JOE_NOTIFICATION_EMAIL=joe.dollinger@gmail.com

# --- Admin (Phase 4 — required) ---
# Comma-separated GitHub usernames allowed in /admin (D-A-02)
ADMIN_GITHUB_LOGINS=joe-dollinger
# Bearer token for /api/cron/* endpoints (>=32 chars; generate with: openssl rand -hex 32)
CRON_SECRET=REPLACE_ME_WITH_32_PLUS_CHARS_HEX_TOKEN

# --- Phase 4 retention + monitor ---
# Supabase Storage bucket name (default works; create the bucket in Supabase dashboard)
SUPABASE_STORAGE_ARCHIVE_BUCKET=transcripts-archive
# BetterStack public status page URL (optional — link target on /admin/health)
BETTERSTACK_DASHBOARD_URL=
# Set to 'false' to disable Anthropic prompt-cache pre-warm in heartbeat cron
# (cost trade-off: ~$15/business-week if true; see CONTEXT D-C-10)
HEARTBEAT_LLM_PREWARM=true

# Canonical production base URL (no trailing slash) used by buildAdminUrl in
# src/lib/email.ts to render clickable admin links in per-session
# notification emails. If unset, code falls back to https://$VERCEL_URL on
# Vercel; if that's also unset (e.g. local dev, custom hosting) the email
# uses a relative /admin/... path and logs a warning rather than emitting a
# localhost link a recruiter can't open. Required in prod.
NEXT_PUBLIC_SITE_URL=https://your-domain.example.com

# ------------------------------------------------------------------------------
# Cloudflare Turnstile (Phase 2 — feature-flagged OFF by default; SAFE-13)
# ------------------------------------------------------------------------------
# To enable the CAPTCHA on the landing email gate:
#   1. Register a Turnstile site at https://dash.cloudflare.com/?to=/:account/turnstile
#   2. Copy the "Site Key" (public) into NEXT_PUBLIC_TURNSTILE_SITE_ID
#   3. Copy the "Secret Key" into TURNSTILE_SECRET_KEY
#   4. Set NEXT_PUBLIC_TURNSTILE_ENABLED=true
#   5. Restart `npm run dev`
# With the flag off (default), all three variables are ignored; EmailGate renders
# without the widget and /api/session skips server-side verification.
#
# Cloudflare also publishes always-pass test keys for local testing:
#   site:   1x00000000000000000000AA
#   secret: 1x0000000000000000000000000000000AA
#
# NEXT_PUBLIC_TURNSTILE_ENABLED=false
# NEXT_PUBLIC_TURNSTILE_SITE_ID=
# TURNSTILE_SECRET_KEY=

# ------------------------------------------------------------------------------
# Phase 5 — eval harness (all OPTIONAL; chat path loads without them)
# ------------------------------------------------------------------------------
# All four are consumed by the eval CLI (`npm run eval`, scripts/run-evals.ts)
# and the weekly drift cron (Plan 05-11). The chat path never reads them.

# Google AI Studio key for Gemini 2.5 Flash (LLM judge).
# Get one free at https://aistudio.google.com/apikey
# Required for: cat 1 (fabrication judge), cat 3 (persona warmth), cat 4 (voice fidelity), cat 5 (refusal warmth)
# Without it, runner code still ships but live smoke runs fail (judge half no-ops).
GOOGLE_GENERATIVE_AI_API_KEY=

# Override the pinned judge model from src/lib/eval-models.ts (default: gemini-2.5-flash).
# Leave empty unless calibrating; orchestrator-locked decision per RESEARCH §1 / Pitfall 4.
EVAL_JUDGE_MODEL=

# Target deployment URL for `npm run eval` runs.
# Local: http://localhost:3000   Preview: https://<vercel-preview-url>   Prod: https://<your-domain>
# Required at run time; not read at module init.
EVAL_TARGET_URL=

# GitHub fine-grained PAT for triggering the eval workflow via repository_dispatch
# from cron-job.org (Plan 05-11). Scope: contents:read + actions:write on this repo only.
# Generate at https://github.com/settings/tokens?type=beta
GH_DISPATCH_TOKEN=
