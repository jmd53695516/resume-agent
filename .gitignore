# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
/test-results/
/playwright-report/
/playwright/.cache/

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# interview transcripts (Joe's local source material; may contain
# coworker / former-employer detail; never commit)
/docs/transcripts/

# Claude Code local cache (runtime artifacts)
/.claude/

# Supabase CLI temp output (runtime artifacts)
/supabase/.temp/

# Eval CLI runtime output (per-run playwright JSON, transient captures, etc.)
# sample-stream.txt is the committed test fixture for src/lib/eval/agent-client.ts
# (Plan 05-03 Task 4) — keep it tracked. Note: must use `.eval-tmp/*` not
# `.eval-tmp/`, because the latter ignores the directory itself and prevents
# git from traversing into it (the negation never applies).
.eval-tmp/*
!.eval-tmp/sample-stream.txt

# Phase 05.1 ephemeral working-state files — pre-phase SHA pin and cat3
# baseline integer used by Task 3 byte-identical verification + D-B-02
# no-regression gate. Cleaned up by Task 4 PART F. Never committed.
.planning/phases/**/.pre-phase-sha
.planning/phases/**/.cat3-baseline
.planning/phases/**/.cat3-baseline-detail
